{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },

    "AllowedHosts": "*",
    "ExternalWeatherApi": {
        "BaseUrl": "https://api.example.com/",
        "ApiKey": "demo-api-key-placeholder",
        "TimeoutSeconds": 5
    },

    "Jwt": {
        "Key": "demo-secret-key-placeholder-for-local-development-only",
        "Issuer": "WeatherGatewayAPI",
        "Audience": "WeatherGatewayAPIUsers"
    }
}