{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
    "AllowedHosts": "*",
    "ExternalWeatherApi": {
        "BaseUrl": "https://api.example.com/",
        "ApiKey": "your-api-key-here",
        "TimeoutSeconds": 5
    },
    "Jwt": {
        "Key": "this-is-a-super-secret-key-12345",
        "Issuer": "WeatherApi",
        "Audience": "WeatherApiUsers"
    }
}
